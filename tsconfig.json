{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "ignoreDeprecations": "5.0",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "paths": {
      "@/*": ["./src/*"],
      "@/lib/*": ["../lib/*"],
      "@/database/*": ["../database/*"]
    }
  },
  "include": [
    "src/**/*",
    "../lib/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
